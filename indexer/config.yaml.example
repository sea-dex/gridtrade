# v2 contract addresses
chains:
  - name: "bsc-testnet"
    chain_id: 97
    rpc_url: "${RPC_URL:-https://rpc.ankr.com/bsc_testnet_chapel}"
    gridex_address: "0xa91a5AAa0BC042200a3391eDb7b02d5B4aa804dB"  # Router
    linear_strategy_address: "0x9D403942473B39123e8dAbeC529011Ae8636e61D"
    geometry_strategy_address: "0xB0281fE94d7f739142ec89c633AFaEACBd3b08e8"
    start_block: ${START_BLOCK:-0}
    block_batch_size: 100
    poll_interval_ms: 2000
    confirmations: 3
    rpc_tpm: ${RPC_TPM:-5}  # max RPC requests per minute (0 = unlimited)
    stablecoins:
      - "0x55d398326f99059fF775485246999027B3197955"  # USDT
      - "0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d"  # USDC

database:
  host: "${DB_HOST:-localhost}"
  port: ${DB_PORT:-5432}
  user: "${DB_USER:-postgres}"
  password: "${DB_PASSWORD:-postgres}"
  dbname: "${DB_NAME:-gridex}"
  sslmode: "${DB_SSLMODE:-disable}"

kafka:
  brokers:
    - "${KAFKA_BROKER:-localhost:9092}"
  topic: "${KAFKA_TOPIC:-gridex-events}"

log:
  level: "${LOG_LEVEL:-info}"
